{
  "name": "korea-stock-mcp",
  "version": "1.4.0",
  "mcpName": "io.github.jjlabsio/korea-stock-mcp",
  "description": "MCP server for korea stock",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "korea-stock-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "release": "bash scripts/release.sh",
    "dev": "node --watch --import tsx/esm src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector tsx src/index.ts",
    "generate-corp-codes": "tsx scripts/generate-corp-codes.ts"
  },
  "keywords": [],
  "author": "jjlabsio",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jjlabsio/korea-stock-mcp.git"
  },
  "homepage": "https://github.com/jjlabsio/korea-stock-mcp#readme",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "adm-zip": "^0.5.16",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.2.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "bumpp": "^10.2.3",
    "changelogen": "^0.6.2",
    "shx": "^0.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  }
}
